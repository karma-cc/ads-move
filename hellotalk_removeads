^https:\/\/api-cn\.hellotalk8\.com\/config-center\/v2\/platform\/banner\?position=non-vip-drawer url script-response-body https://raw.githubusercontent.com/karma-cc/ads-move/refs/heads/main/hellotalkvip_js
